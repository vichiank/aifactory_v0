{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact form submission from a user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the person sending the inquiry."
        },
        "message": {
          "type": "string",
          "description": "The message content of the inquiry."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the inquiry was sent."
        }
      },
      "required": ["email", "message", "timestamp"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of contact form inquiries."
    }
  }
}
